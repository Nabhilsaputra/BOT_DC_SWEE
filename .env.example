# ─── Discord Bot ─────────────────────────────────────────────────────────────
# Token bot Discord (dari https://discord.com/developers/applications)
DISCORD_TOKEN=token_discord_kamu

# ID channel tempat log scan real-time dikirim
DISCORD_CHANNEL_ID=id_channel_discord

# ─── Database ─────────────────────────────────────────────────────────────────
# Railway otomatis inject DATABASE_URL kalau pakai plugin PostgreSQL
# Untuk lokal, isi manual:
# DATABASE_URL=postgresql://user:password@localhost:5432/klubrenang
DATABASE_URL=

# ─── URL Publik (untuk QR code) ───────────────────────────────────────────────
# Railway otomatis inject RAILWAY_PUBLIC_DOMAIN — set BASE_URL ke:
#   https://<nama-proyek>.up.railway.app
# Ini digunakan untuk membuat link QR code yang valid di bot Discord.
# Untuk lokal: http://localhost:3000
BASE_URL=https://nama-proyek-kamu.up.railway.app

# ─── Port ─────────────────────────────────────────────────────────────────────
# Railway inject otomatis, tidak perlu diisi di Railway
PORT=3000
